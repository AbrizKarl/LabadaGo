<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: the backend runs on plain http during development, reachable
  from the emulator at 10.0.2.2 (the special alias for the host machine's
  localhost). This does NOT apply to release builds.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
